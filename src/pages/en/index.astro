---
// src/pages/en/index.astro
import Base from '../../layouts/Base.astro';
import About from '../../components/About.astro';
import Publications from '../../components/Publications.astro';
import publicationsData from '../../data/publications.json';
import type { Publication } from '../../types';

const lang = 'en' as const;
const pubs = publicationsData as Publication[];
const ownerName = '韩汪洋';
---

<Base
  title="Hawaii Ocean — Academic Homepage"
  description="M.S. student in chip front-end design. Research interests include AI accelerator architecture and RISC-V processor design."
  currentPath={Astro.url.pathname}
>
  <About lang={lang} />
  <Publications lang={lang} publications={pubs} ownerName={ownerName} />
</Base>
