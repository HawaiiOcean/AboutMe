---
// src/layouts/Base.astro
import { getLangFromUrl } from '../i18n/utils';
import Sidebar from '../components/Sidebar.astro';
import ContentNav from '../components/ContentNav.astro';
import profileData from '../data/profile.json';
import type { Profile } from '../types';

interface Props {
  title: string;
  description: string;
  currentPath: string;
}

const { title, description, currentPath } = Astro.props;
const url = new URL(currentPath, Astro.site ?? 'http://localhost:4321');
const lang = getLangFromUrl(url);
const profile = profileData as unknown as Profile;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Cormorant Garamond (serif) + Inter (sans) + IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="lg:flex">
      <Sidebar lang={lang} profile={profile} currentPath={currentPath} />
      <div class="lg:ml-[300px] min-h-screen w-full">
        <ContentNav lang={lang} />
        <main class="content-fade-mask px-8 py-12 max-w-3xl mx-auto">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
