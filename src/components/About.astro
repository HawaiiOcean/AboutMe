---
// src/components/About.astro

// Import markdown as raw text, then render with basic markdown-to-HTML
const zhModules = import.meta.glob('../data/zh/about.md', { eager: true, query: '?raw' });
const enModules = import.meta.glob('../data/en/about.md', { eager: true, query: '?raw' });
const zhRaw = (zhModules['../data/zh/about.md'] as any)?.default ?? '';
const enRaw = (enModules['../data/en/about.md'] as any)?.default ?? '';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const heading = lang === 'zh' ? 'About' : 'About';
const raw = lang === 'zh' ? zhRaw : enRaw;

function renderMd(text: string): string {
  const lines = text.split('\n');
  let html = '';
  let inList = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (!trimmed) {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }

    // Skip frontmatter
    if (trimmed === '---') continue;
    if (trimmed.startsWith('title:')) continue;

    // H3
    if (trimmed.startsWith('### ')) {
      if (inList) { html += '</ul>'; inList = false; }
      html += `<h3 class="text-lg font-serif font-semibold text-text-primary mt-8 mb-3">${trimmed.slice(4)}</h3>`;
    }
    // H2
    else if (trimmed.startsWith('## ')) {
      if (inList) { html += '</ul>'; inList = false; }
      html += `<h2 class="text-lg font-serif font-semibold text-text-primary mt-8 mb-3">${trimmed.slice(3)}</h2>`;
    }
    // List item
    else if (trimmed.startsWith('- ')) {
      if (!inList) { html += '<ul class="list-disc pl-5 space-y-1">'; inList = true; }
      html += `<li>${processInline(trimmed.slice(2))}</li>`;
    }
    // Paragraph
    else {
      if (inList) { html += '</ul>'; inList = false; }
      html += `<p class="mb-4">${processInline(trimmed)}</p>`;
    }
  }
  if (inList) { html += '</ul>'; }

  return html;
}

function processInline(text: string): string {
  // **bold** -> <strong>
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold">$1</strong>');
  // Advisor highlight: text containing "Advisor:" or "导师：" gets gold treatment
  text = text.replace(/(Advisor:|导师：)\s*(.+)/g,
    '<span class="text-text-secondary">$1</span> <span class="text-accent-light font-medium">$2</span>');
  return text;
}
---

<section id="about" class="py-16">
  <h2 class="font-serif text-2xl font-bold text-text-primary mb-6">{heading}</h2>
  <div class="max-w-none text-text-secondary leading-relaxed">
    <div set:html={renderMd(raw)} />
  </div>
</section>
