---
// src/components/PublicationCard.astro
import type { Publication } from '../types';

interface Props {
  pub: Publication;
  lang: 'zh' | 'en';
  ownerName: string;
}

const { pub, lang, ownerName } = Astro.props;
---

<article class="bg-surface rounded-xl p-5 mb-4">
  <!-- Title -->
  <h3 class="font-serif font-semibold text-base text-text-primary mb-1.5 leading-snug">
    {pub.title[lang]}
  </h3>

  <!-- Authors -->
  <p class="text-sm leading-relaxed">
    {pub.authors.map((author, i) => (
      <span>
        <span class={author === ownerName ? 'text-accent-light font-medium' : 'text-text-secondary'}>
          {author}
        </span>
        {i < pub.authors.length - 1 && <span class="text-text-secondary">, </span>}
      </span>
    ))}
  </p>

  <!-- Journal -->
  <p class="text-xs text-accent-light mt-1 font-medium">
    {pub.journal[lang]}
  </p>

  <!-- Description -->
  <p class="text-sm text-text-secondary mt-2.5 leading-relaxed">
    {pub.description[lang]}
  </p>

  <!-- Link -->
  {pub.link && (
    <a
      href={pub.link}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-2 text-xs text-accent hover:text-accent-light transition-colors"
    >
      {pub.doi ? `DOI: ${pub.doi}` : (lang === 'zh' ? '查看论文 →' : 'View Paper →')}
    </a>
  )}
</article>
