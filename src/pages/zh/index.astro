---
// src/pages/zh/index.astro
import Base from '../../layouts/Base.astro';
import About from '../../components/About.astro';
import Publications from '../../components/Publications.astro';
import publicationsData from '../../data/publications.json';
import type { Publication } from '../../types';

const lang = 'zh' as const;
const pubs = publicationsData as Publication[];
const ownerName = '韩汪洋';
---

<Base
  title="桐月不寒 — 个人学术主页"
  description="芯片前端设计方向研究生，研究兴趣包括AI加速器架构、RISC-V处理器设计。"
  currentPath={Astro.url.pathname}
>
  <About lang={lang} />
  <Publications lang={lang} publications={pubs} ownerName={ownerName} />
</Base>
